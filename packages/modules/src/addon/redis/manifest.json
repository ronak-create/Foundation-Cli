{
  "id": "plugin-redis",
  "name": "Redis Cache",
  "version": "1.0.0",
  "description": "Redis caching layer with type-safe helpers for get/set/delete and optional session storage",
  "category": "database",
  "runtime": "node",
  "dependencies": [
    { "name": "redis", "version": "^4.6.14", "scope": "dependencies" },
    { "name": "@types/redis", "version": "^4.0.11", "scope": "devDependencies" }
  ],
  "files": [
    { "relativePath": "src/cache/redis-client.ts", "content": "" },
    { "relativePath": "src/cache/redis-cache.ts", "content": "" },
    { "relativePath": "src/cache/redis-session.ts", "content": "" }
  ],
  "configPatches": [
    {
      "targetFile": ".env.example",
      "merge": { "REDIS_URL": "redis://localhost:6379" }
    }
  ],
  "compatibility": { "requires": [], "conflicts": [] },
  "tags": ["cache", "redis", "session", "pub-sub"]
}