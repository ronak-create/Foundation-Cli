{
  "name": "@systemlabs/foundation-modules",
  "description": "Built-in modules for databases, backends, auth providers, and services.",
  "version": "0.1.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ronak-create/Foundation-Cli.git"
  },
  "homepage": "https://github.com/ronak-create/Foundation-Cli#readme",
  "bugs": {
    "url": "https://github.com/ronak-create/Foundation-Cli/issues"
  },
  "keywords": [
    "cli",
    "scaffolding",
    "foundation"
  ],  
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./registry-loader": {
      "import": "./dist/registry-loader.js",
      "types": "./dist/registry-loader.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist *.tsbuildinfo",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@systemlabs/foundation-plugin-sdk": "0.1.0",
    "@systemlabs/foundation-core": "0.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
