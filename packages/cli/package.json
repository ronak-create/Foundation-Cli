{
  "name": "@foundation-cli/cli",
  "version": "0.0.1",
  "type": "module",
  "bin": {
    "foundation": "./dist/bin.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist *.tsbuildinfo",
    "test": "vitest run --reporter=verbose"
  },
  "dependencies": {
    "@foundation-cli/core": "workspace:*",
    "@foundation-cli/modules": "workspace:*",
    "@foundation-cli/plugin-sdk": "workspace:*",
    "@inquirer/prompts": "^5.3.2",
    "chalk": "^5.3.0",
    "ora": "^8.1.0",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/prompts": "^2.4.9",
    "tsup": "^8.0.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}