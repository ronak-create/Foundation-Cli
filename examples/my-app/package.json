{
  "devDependencies": {
    "npm-run-all2": "^7.0.2",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "typescript": "^5.4.5",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "tsx": "^4.11.0",
    "@types/pg": "^8.11.6",
    "@types/jsonwebtoken": "^9.0.6",
    "tailwindcss": "^3.4.4",
    "postcss": "^8.4.38",
    "autoprefixer": "^10.4.19"
  },
  "scripts": {
    "dev": "npm-run-all2 --parallel dev:next dev:server",
    "build": "npm-run-all2 --parallel build:next build:tsc",
    "start": "npm-run-all2 --parallel start:next start:server",
    "lint": "next lint",
    "dev:next": "next dev",
    "dev:server": "tsx watch src/server.ts",
    "build:next": "next build",
    "build:tsc": "tsc",
    "start:next": "next start",
    "start:server": "node dist/server.js",
    "docker:build": "docker build -t my-app .",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  },
  "name": "my-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "next": "14.2.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "express": "^4.19.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "dotenv": "^16.4.5",
    "pg": "^8.11.5",
    "jsonwebtoken": "^9.0.2"
  }
}