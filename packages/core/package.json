{
  "name": "@systemlabs/foundation-core",
  "description": "Core engine and utilities powering the Foundation CLI.",
  "version": "0.2.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ronak-create/Foundation-Cli.git"
  },
  "homepage": "https://github.com/ronak-create/Foundation-Cli#readme",
  "bugs": {
    "url": "https://github.com/ronak-create/Foundation-Cli/issues"
  },
  "keywords": [
    "cli",
    "scaffolding",
    "foundation"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist *.tsbuildinfo",
    "test": "vitest run --reporter=verbose"
  },
  "dependencies": {
    "@systemlabs/foundation-plugin-sdk": "workspace:*",
    "ejs": "^3.1.10",
    "execa": "^9.3.0",
    "ajv": "^8.12.0",
    "ajv-formats": "^2.1.1",
    "js-yaml": "^4.1.0",
    "lodash-es": "^4.17.21"
  },
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
