{
  "name": "@systemlabs/foundation-cli",
  "description": "Foundation CLI — scaffold and configure full-stack applications with modular architecture.",
  "version": "0.3.1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ronak-create/Foundation-Cli.git"
  },
  "homepage": "https://github.com/ronak-create/Foundation-Cli#readme",
  "bugs": {
    "url": "https://github.com/ronak-create/Foundation-Cli/issues"
  },
  "keywords": [
    "cli",
    "scaffolding",
    "foundation"
  ],
  "type": "module",
  "bin": {
    "foundation": "./dist/bin.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist *.tsbuildinfo",
    "test": "vitest run --reporter=verbose"
  },
  "dependencies": {
    "@systemlabs/foundation-core": "workspace:*",
    "@systemlabs/foundation-modules": "workspace:*",
    "@systemlabs/foundation-plugin-sdk": "workspace:*",
    "@inquirer/prompts": "^5.3.2",
    "chalk": "^5.3.0",
    "ora": "^8.1.0",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/prompts": "^2.4.9",
    "tsup": "^8.0.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
