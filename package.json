{
  "name": "foundation-cli-monorepo",
  "description": "Foundation CLI monorepo — modular full-stack scaffolding and tooling.",
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\""
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.5",
    "turbo": "^2.0.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "pnpm": {
    "overrides": {
      "@astrojs/sitemap@*": "3.1.2",
      "sitemap": "7.1.2"
    }
  },
  "packageManager": "pnpm@9.0.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ronak-create/Foundation-Cli.git"
  },
  "homepage": "https://github.com/ronak-create/Foundation-Cli#readme",
  "bugs": {
    "url": "https://github.com/ronak-create/Foundation-Cli/issues"
  },
  "keywords": [
    "cli",
    "scaffolding",
    "foundation"
  ]
}
