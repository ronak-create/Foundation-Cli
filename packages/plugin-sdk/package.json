{
  "name": "@systemlabs/foundation-plugin-sdk",
  "description": "SDK for building custom plugins and modules for the Foundation ecosystem.",
  "version": "0.3.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ronak-create/Foundation-Cli.git"
  },
  "homepage": "https://github.com/ronak-create/Foundation-Cli#readme",
  "bugs": {
    "url": "https://github.com/ronak-create/Foundation-Cli/issues"
  },
  "keywords": [
    "cli",
    "scaffolding",
    "foundation"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist *.tsbuildinfo",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "ajv": "^8.12.0",
    "ajv-formats": "^3.0.1"
  },
  "publishConfig": {
    "access": "public"
  }
}